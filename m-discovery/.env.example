DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=music
GOOGLE_API_KEY=your_google_api_key_here

# Host path to your local music library, bind-mounted into the app
# container read-only at /music. Point library scans at /music.
MUSIC_LIBRARY_PATH=/path/to/your/music/library

# TheAudioDB (artist bio/photo). "123" is their public free test key
# (30 req/min, shared by everyone using it) - swap in your own key from
# theaudiodb.com if you hit rate limits.
AUDIODB_API_KEY=123

# WiiM/LinkPlay devices to cast to: "Name:ip,Name2:ip2"
WIIM_DEVICES=Living Room:192.168.1.50,Bedroom:192.168.1.51

# Chromecast/Google TV devices to cast to, same "Name:ip,Name2:ip2" format.
# Connecting by known IP (rather than mDNS discovery) since multicast doesn't
# reliably reach the app container under Docker.
CHROMECAST_DEVICES=Living Room TV:192.168.1.60,Bedroom TV:192.168.1.61

# LAN address WiiM/Chromecast devices use to reach this app's stream/artwork endpoints
PUBLIC_BASE_URL=http://192.168.1.10:6009

# Spotify app credentials (developer.spotify.com/dashboard -> app -> Settings).
# Used for Spotify Connect (Authorization Code flow: real user login, needed
# to control playback and read your playlists).
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Spotify's OAuth redirect_uri must be https:// (or exactly http://localhost) -
# PUBLIC_BASE_URL above is plain HTTP on a LAN IP, so this points at an HTTPS
# front door just for that one redirect (falls back to PUBLIC_BASE_URL if
# unset, e.g. if you're already serving over HTTPS). This exact value +
# "/api/spotify/auth/callback" must be registered as a Redirect URI in the
# Spotify dashboard. See frontend/nginx.conf's self-signed HTTPS listener
# (port 443, mapped to host 6443 in docker-compose.yml) for one way to get one.
SPOTIFY_REDIRECT_BASE_URL=https://192.168.1.10:6443

# Discogs personal access token (discogs.com/settings/developers) - used for
# album artwork lookups, especially better regional/vinyl coverage than the
# other free sources.
DISCOGS_TOKEN=your_discogs_token
