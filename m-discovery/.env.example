DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=music
GOOGLE_API_KEY=your_google_api_key_here

# Host path to your local music library, bind-mounted into the app
# container read-only at /music. Point library scans at /music.
MUSIC_LIBRARY_PATH=/path/to/your/music/library

# TheAudioDB (artist bio/photo). "123" is their public free test key
# (30 req/min, shared by everyone using it) - swap in your own key from
# theaudiodb.com if you hit rate limits.
AUDIODB_API_KEY=123

# WiiM/LinkPlay devices to cast to: "Name:ip,Name2:ip2"
WIIM_DEVICES=Living Room:192.168.1.50,Bedroom:192.168.1.51

# Chromecast/Google TV devices to cast to, same "Name:ip,Name2:ip2" format.
# Connecting by known IP (rather than mDNS discovery) since multicast doesn't
# reliably reach the app container under Docker.
CHROMECAST_DEVICES=Living Room TV:192.168.1.60,Bedroom TV:192.168.1.61

# LAN address WiiM/Chromecast devices use to reach this app's stream/artwork endpoints
PUBLIC_BASE_URL=http://192.168.1.10:6009

# Spotify app credentials (developer.spotify.com/dashboard -> app -> Settings).
# Client Credentials flow only (app-level catalog access, no user login) -
# used for metadata enrichment (search/lookup), not playback control.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
